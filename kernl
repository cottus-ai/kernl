#!/usr/bin/env python3
"""
kernl — minimal agent runtime

Commands:
  kernl build <agent.py>                Build a .kb bundle
  kernl run <bundle.kb> '<input_json>'  Execute an agent
  kernl inspect <bundle.kb>             Show bundle metadata
  kernl exec <agent.py> '<input_json>'  Build + run in one step
"""
import json
import os
import sys
import time

# Add project root to path
PROJECT_ROOT = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, PROJECT_ROOT)


def cmd_build(args):
    from src.build import build
    if not args:
        print("Usage: kernl build <agent.py> [--output <path>]", file=sys.stderr)
        sys.exit(1)

    agent_path = args[0]
    output = None
    if "--output" in args:
        idx = args.index("--output")
        output = args[idx + 1]

    t_start = time.monotonic()
    path, size, hash_, budget = build(agent_path, output)
    t_elapsed = (time.monotonic() - t_start) * 1000

    print(f"  agent:   {agent_path}")
    print(f"  bundle:  {path}")
    print(f"  size:    {size:,} bytes ({size / 1024:.1f} KB)")
    print(f"  hash:    {hash_}")
    print(f"  memory:  {budget['total_bytes'] // 1024} KB budget")
    print(f"  built in {t_elapsed:.1f}ms")


def cmd_run(args):
    if len(args) < 2:
        print("Usage: kernl run <bundle.kb> '<input_json>' [--no-sandbox] [--dry-run] [--allow-network]", file=sys.stderr)
        sys.exit(1)

    kb_path = args[0]
    input_json = args[1]
    use_sandbox = "--no-sandbox" not in args
    dry_run = "--dry-run" in args
    allow_network = "--allow-network" in args

    if dry_run:
        os.environ["KERNL_DRY_RUN"] = "1"

    try:
        input_data = json.loads(input_json)
    except json.JSONDecodeError:
        print(f"ERROR: invalid input JSON", file=sys.stderr)
        sys.exit(1)

    from src.run import run
    result = run(kb_path, input_data, use_sandbox=use_sandbox, dry_run=dry_run,
                 allow_network=allow_network)

    status = result.get("status", "unknown")
    output = result.get("output", "")
    steps = result.get("steps", 0)
    tool_calls = result.get("tool_calls", [])
    total_ms = result.get("total_ms", 0)
    agent_ms = result.get("elapsed_ms", 0)
    isolation = result.get("isolation", "unknown")

    print(f"  agent:     {result.get('agent', '?')}")
    print(f"  hash:      {result.get('hash', '?')}")
    print(f"  isolation: {isolation}")
    print(f"  status:    {status}")
    print(f"  steps:     {steps}")

    if tool_calls:
        print(f"  tools:     {len(tool_calls)} calls")
        for tc in tool_calls:
            print(f"             {tc['tool']}({json.dumps(tc['input'])}) → {tc['output'][:80]}")

    print(f"  time:      {total_ms:.0f}ms total, {agent_ms:.0f}ms agent")
    print(f"  memory:    {result.get('memory_budget_kb', '?')} KB budget")
    print()
    print("--- output ---")
    print(output)


def cmd_inspect(args):
    import tarfile
    if not args:
        print("Usage: kernl inspect <bundle.kb>", file=sys.stderr)
        sys.exit(1)

    with tarfile.open(args[0], "r:gz") as tar:
        # List contents
        print(f"  bundle: {args[0]}")
        print(f"  files:")
        for member in tar.getmembers():
            print(f"    {member.name:20s}  {member.size:>8,} bytes")

        # Extract and show manifest
        manifest = json.load(tar.extractfile("manifest.json"))
        agent = manifest["agent"]
        print(f"  agent:   {agent['name']}")
        print(f"  model:   {agent['model']}")
        print(f"  steps:   {agent['max_steps']}")
        print(f"  tools:   {[t['name'] for t in agent['tools']]}")
        print(f"  state:   {agent['state_fields']}")
        print(f"  hash:    {manifest['content_hash']}")
        budget = manifest["memory_budget"]
        print(f"  memory:  {budget['total_bytes'] // 1024} KB budget "
              f"(stack: {budget['stack_bytes'] // 1024} KB, "
              f"heap: {budget['heap_bytes'] // 1024} KB)")


def cmd_exec(args):
    """Build + run in one step."""
    from src.build import build

    if len(args) < 2:
        print("Usage: kernl exec <agent.py> '<input_json>' [--no-sandbox]", file=sys.stderr)
        sys.exit(1)

    agent_path = args[0]
    input_json = args[1]
    use_sandbox = "--no-sandbox" not in args
    dry_run = "--dry-run" in args
    allow_network = "--allow-network" in args

    if dry_run:
        os.environ["KERNL_DRY_RUN"] = "1"

    try:
        input_data = json.loads(input_json)
    except json.JSONDecodeError:
        print(f"ERROR: invalid input JSON", file=sys.stderr)
        sys.exit(1)

    # Build
    t_build = time.monotonic()
    kb_path, size, hash_, budget = build(agent_path)
    build_ms = (time.monotonic() - t_build) * 1000
    print(f"  build:     {build_ms:.1f}ms ({size / 1024:.1f} KB)")

    from src.run import run
    result = run(kb_path, input_data, use_sandbox=use_sandbox, dry_run=dry_run,
                 allow_network=allow_network)

    # Clean up bundle
    os.unlink(kb_path)

    status = result.get("status", "unknown")
    output = result.get("output", "")
    steps = result.get("steps", 0)
    tool_calls = result.get("tool_calls", [])
    total_ms = result.get("total_ms", 0)
    agent_ms = result.get("elapsed_ms", 0)
    isolation = result.get("isolation", "unknown")

    print(f"  agent:     {result.get('agent', '?')}")
    print(f"  isolation: {isolation}")
    print(f"  status:    {status}")
    print(f"  steps:     {steps}")

    if tool_calls:
        print(f"  tools:     {len(tool_calls)} calls")
        for tc in tool_calls:
            print(f"             {tc['tool']}({json.dumps(tc['input'])}) → {tc['output'][:80]}")

    print(f"  time:      {total_ms:.0f}ms total, {agent_ms:.0f}ms agent")
    print()
    print("--- output ---")
    print(output)


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        print(__doc__.strip())
        sys.exit(0)

    command = sys.argv[1]
    args = sys.argv[2:]

    commands = {
        "build": cmd_build,
        "run": cmd_run,
        "inspect": cmd_inspect,
        "exec": cmd_exec,
    }

    if command not in commands:
        print(f"Unknown command: {command}", file=sys.stderr)
        print(f"Available: {', '.join(commands)}", file=sys.stderr)
        sys.exit(1)

    commands[command](args)


if __name__ == "__main__":
    main()
