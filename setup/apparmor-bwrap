# AppArmor profile for bubblewrap (bwrap) — grants user namespace creation.
#
# Required on Ubuntu 24.04+ where kernel.apparmor_restrict_unprivileged_userns=1.
# Without this profile, bwrap cannot create the mount/PID/IPC namespaces
# that Kernl uses for agent isolation.
#
# Install:
#   sudo cp setup/apparmor-bwrap /etc/apparmor.d/bwrap
#   sudo apparmor_parser -r /etc/apparmor.d/bwrap

abi <abi/4.0>,
include <tunables/global>

profile bwrap /usr/bin/bwrap flags=(unconfined) {
  userns,

  include if exists <local/bwrap>
}
